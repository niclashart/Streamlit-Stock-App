# API keys
DEEPSEEK_API_KEY=your_api_key_here

# Database configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=stockapp
DB_USER=postgres
DB_PASSWORD=postgres
# Optional: provide full DB URL instead of individual params
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stockapp

# JWT Settings
JWT_SECRET_KEY=your_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=144000  # 2400 hours
